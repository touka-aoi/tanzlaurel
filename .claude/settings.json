{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(go:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)"
    ],
    "allowedTools": [
      "mcp__serena__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./build)"
    ]
  },
  "plansDirectory": "./.claude/plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/go-post-edit.sh",
            "timeout": 120,
            "statusMessage": "Running Go linters..."
          }
        ]
      }
    ]
  }
}
